# App Configuration
APP_NAME="Odds on Deck"

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key_here"   # public (browser) key — RLS must be enabled
SUPABASE_SECRET_KEY="your_service_role_key_here"      # server-only — NEVER expose to the client

# APIs
ODDS_API_KEY="your_odds_api_key_here"

# Admin/cron shared secret — protects admin write endpoints
# (validation/update-result, nfl/refresh-data, nfl/refresh-current-week, parlays/validate).
# Pass it as "Authorization: Bearer <CRON_SECRET>" or "x-api-key: <CRON_SECRET>".
CRON_SECRET="generate_a_long_random_string_here"

# Next.js
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

